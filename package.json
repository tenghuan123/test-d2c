{
  "name": "test-d2c",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "dsl:build": "node scripts/dsl/build-dsl.mjs",
    "dsl:build:asset": "node scripts/dsl/build-from-assets.mjs",
    "dsl:validate": "node scripts/dsl/validate.mjs",
    "dsl:impact": "node scripts/dsl/impact.mjs",
    "dsl:diff": "node scripts/dsl/diff-snapshot.mjs",
    "dsl:tailwind": "node scripts/dsl/to-tailwind.mjs",
    "dsl:semantic": "node scripts/semantic-inference.cjs",
    "dsl:codegen": "node scripts/dsl/codegen.mjs && npx prettier --write \"app/generated/**/*.tsx\"",
    "dsl:pipeline": "npm run dsl:build:asset && npm run dsl:validate && npm run dsl:semantic && npm run dsl:tailwind && npm run dsl:codegen",
    "test": "node --test tests/**/*.test.mjs"
  },
  "dependencies": {
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "isbot": "^5.1.31",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.12.0"
  },
  "devDependencies": {
    "@react-router/dev": "7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.18.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4"
  }
}